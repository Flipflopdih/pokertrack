+  {x:'79%', y:'24%'},  // seat 1 — top right
+  {x:'90%', y:'46%'},  // seat 2 — right
+  {x:'79%', y:'68%'},  // seat 3 — bottom right
+  {x:'50%', y:'75%'},  // seat 4 — bottom center (not used — player sits here)
+  {x:'21%', y:'68%'},  // seat 5 — bottom left
