+.btn-sm.on{border-color:var(--gold);color:var(--gold-l);background:rgba(201,168,76,.16)}
+
+/* reaction palette + floating emoji */
+#react-palette{position:absolute;top:46px;right:120px;background:rgba(8,16,11,.96);border:1px solid rgba(201,168,76,.25);border-radius:12px;padding:8px;display:flex;gap:4px;flex-wrap:wrap;width:200px;z-index:120;box-shadow:0 10px 26px rgba(0,0,0,.55)}
+#react-palette button{background:none;border:none;font-size:22px;cursor:pointer;padding:4px;border-radius:8px;transition:transform .1s,background .12s}
+#react-palette button:hover{background:rgba(255,255,255,.08);transform:scale(1.15)}
+.react-float{position:absolute;transform:translate(-50%,-50%);font-size:34px;z-index:30;pointer-events:none;animation:rfloat 1.8s ease-out forwards;filter:drop-shadow(0 3px 6px rgba(0,0,0,.5))}
+@keyframes rfloat{0%{opacity:0;transform:translate(-50%,-30%) scale(.4)}15%{opacity:1;transform:translate(-50%,-90%) scale(1.2)}70%{opacity:1}100%{opacity:0;transform:translate(-50%,-220%) scale(1)}}
+
+/* all-in equity bar on seats + hero */
+.eq-wrap{display:flex;align-items:center;gap:5px;width:96px;margin-top:1px}
