+
+/* show / muck prompt */
+#showmuck{position:fixed;bottom:96px;left:50%;transform:translateX(-50%);z-index:95;display:flex;align-items:center;gap:10px;background:rgba(8,16,11,.96);border:1px solid rgba(201,168,76,.3);border-radius:14px;padding:10px 14px;box-shadow:0 10px 28px rgba(0,0,0,.6)}
+#showmuck span{font-size:13px;color:rgba(240,237,228,.85)}
