+/* ── pre-action bar ── */
+#preaction{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);z-index:89;display:flex;align-items:center;gap:8px;background:rgba(8,16,11,.9);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:8px 12px;box-shadow:0 6px 16px rgba(0,0,0,.5)}
