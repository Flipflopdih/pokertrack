+// Fire an immediate minimum-legal raise/bet (no panel).
+function minRaise() {
+  if (!raiseCtx) return;
+  document.getElementById('rslider').value = raiseCtx.lo;
+  send('raise');
+  showRaisePanel(false);
+}
