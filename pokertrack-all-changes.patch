--- /dev/null
+++ b/public/css/styles.css
@@ -0,0 +1,451 @@
+*{box-sizing:border-box;margin:0;padding:0}
+:root{--felt:#1b3d2a;--felt-mid:#1e4830;--felt-dark:#0f2017;--rail:#5c3d1e;--rail-dark:#3a2510;--gold:#c9a84c;--gold-l:#e8cc7a}
+body{font-family:'DM Sans',sans-serif;background:#0c1a10;color:#f0ede4;min-height:100vh;overflow-x:hidden}
+.screen{display:none;min-height:100vh}
+.screen.active{display:flex}
+
+/* ── LOBBY ── */
+#s-lobby{align-items:center;justify-content:center;padding:20px;background:radial-gradient(ellipse at 50% 55%,#1a3a2a,#0c1a10 70%)}
+#lobby-box{background:rgba(12,26,16,.97);border:1px solid rgba(201,168,76,.2);border-radius:20px;padding:48px 44px;width:100%;max-width:480px;text-align:center}
+#lobby-box h1{font-family:'Playfair Display',serif;font-size:38px;color:var(--gold-l);margin-bottom:4px}
+.l-sub{font-size:13px;color:rgba(255,255,255,.35);margin-bottom:28px}
+.tabs{display:flex;border:1px solid rgba(255,255,255,.1);border-radius:10px;overflow:hidden;margin-bottom:22px}
+.tab{flex:1;padding:10px;font-size:14px;font-weight:500;cursor:pointer;background:transparent;border:none;color:rgba(255,255,255,.4);transition:all .15s;font-family:'DM Sans',sans-serif}
+.tab.active{background:rgba(201,168,76,.15);color:var(--gold-l)}
+.lf{margin-bottom:12px;text-align:left}
+.lf label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.3);margin-bottom:5px}
+.lf input,.lf select{width:100%;padding:10px 13px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:#f0ede4;font-family:'DM Sans',sans-serif;font-size:15px}
+.lf input:focus,.lf select:focus{outline:none;border-color:var(--gold)}
+.lf select option{background:#0c1a10}
+.lf-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
+.btn-gold{width:100%;padding:13px;background:var(--gold);color:#1a1a1a;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:16px;font-weight:600;cursor:pointer;transition:background .15s;margin-top:6px}
+.btn-gold:hover{background:var(--gold-l)}
+.link-box{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:14px;margin-top:14px;text-align:left;display:none}
+.link-box.show{display:block}
+.lb-label{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:rgba(255,255,255,.3);margin-bottom:5px}
+.lb-url{font-family:'DM Mono',monospace;font-size:12px;color:var(--gold-l);word-break:break-all;margin-bottom:8px}
+.btn-copy{padding:6px 14px;background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.25);color:var(--gold-l);border-radius:7px;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif}
+
+/* ── SEAT CHOOSER ── */
+#s-seats{align-items:center;justify-content:center;padding:20px;background:radial-gradient(ellipse at 50% 55%,#1a3a2a,#0c1a10 70%);flex-direction:column;gap:20px}
+#seat-box{background:rgba(12,26,16,.97);border:1px solid rgba(201,168,76,.2);border-radius:20px;padding:32px 36px;width:100%;max-width:600px;text-align:center}
+#seat-box h2{font-family:'Playfair Display',serif;font-size:26px;color:var(--gold-l);margin-bottom:6px}
+.seat-sub{font-size:13px;color:rgba(255,255,255,.35);margin-bottom:24px}
+.seat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
+.seat-btn{padding:14px 8px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);cursor:pointer;transition:all .2s;text-align:center}
+.seat-btn:hover{border-color:rgba(201,168,76,.4);background:rgba(201,168,76,.08)}
+.seat-btn.taken{opacity:.4;cursor:not-allowed;border-color:rgba(255,255,255,.05)}
+.seat-btn.taken:hover{border-color:rgba(255,255,255,.05);background:rgba(255,255,255,.04)}
+.seat-btn.mine{border-color:var(--gold);background:rgba(201,168,76,.12)}
+.sb-num{font-size:11px;color:rgba(255,255,255,.3);margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em}
+.sb-name{font-size:13px;font-weight:500;color:#f0ede4;min-height:18px}
+.sb-chips{font-size:11px;font-family:'DM Mono',monospace;color:var(--gold-l)}
+.waiting-players{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:16px}
+#btn-start-game{display:none}
+
+/* ── GAME ── */
+#s-game{flex-direction:column}
+#topbar{background:rgba(0,0,0,.65);backdrop-filter:blur(8px);border-bottom:1px solid rgba(201,168,76,.1);padding:8px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:80;flex-shrink:0;gap:8px}
+.tb-left{display:flex;align-items:center;gap:10px}
+.tb-logo{font-family:'Playfair Display',serif;font-size:16px;color:var(--gold-l)}
+.tb-hand{font-size:11px;color:rgba(255,255,255,.3);font-family:'DM Mono',monospace}
+.tb-blinds{font-size:11px;color:var(--gold-l);font-family:'DM Mono',monospace;padding:3px 9px;border:1px solid rgba(201,168,76,.25);border-radius:6px;background:rgba(201,168,76,.08)}
+.tb-code{font-size:11px;color:rgba(255,255,255,.25);font-family:'DM Mono',monospace;padding:3px 8px;border:1px solid rgba(255,255,255,.1);border-radius:6px;cursor:pointer}
+.tb-code:hover{border-color:rgba(201,168,76,.3);color:var(--gold-l)}
+.tb-right{display:flex;gap:8px;align-items:center}
+.btn-sm{padding:6px 14px;border-radius:7px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);color:#f0ede4;transition:all .14s}
+.btn-sm:hover{background:rgba(255,255,255,.12)}
+.btn-sm.red{border-color:rgba(231,76,60,.3);color:#e74c3c}.btn-sm.red:hover{background:rgba(231,76,60,.12)}
+
+#table-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:26px 26px 150px}
+#table{position:relative;width:100%;max-width:1340px;min-height:680px;margin:0 auto;
+  background:radial-gradient(ellipse 72% 74% at 50% 42%,#2a7049 0%,#1d5236 55%,#103225 100%);
+  border-radius:300px/180px;border:14px solid #5c3d1e;
+  box-shadow:0 0 0 5px #3a2510, 0 0 0 7px rgba(201,168,76,.28), 0 42px 90px rgba(0,0,0,.85), inset 0 3px 16px rgba(255,255,255,.05), inset 0 -14px 46px rgba(0,0,0,.45);
+  padding:54px 100px 64px}
+#table::before{content:'';position:absolute;inset:20px;border-radius:280px/165px;border:2px solid rgba(201,168,76,.16);pointer-events:none}
+#table-logo{position:absolute;top:50%;left:50%;transform:translate(-50%,-185%);font-family:'Playfair Display',serif;font-size:30px;letter-spacing:.05em;color:rgba(201,168,76,.10);pointer-events:none;white-space:nowrap}
+#think{position:absolute;top:14px;left:50%;transform:translateX(-50%);font-size:12px;color:rgba(255,255,255,.4);font-style:italic;white-space:nowrap;pointer-events:none;transition:opacity .3s}
+
+/* SEATS ON TABLE */
+.tseat{position:absolute;display:flex;flex-direction:column;align-items:center;gap:5px;transform:translate(-50%,-50%);width:132px;z-index:4}
+.tseat .av{width:54px;height:54px;border-radius:50%;background:radial-gradient(circle at 50% 34%,#244531,#132318);border:2.5px solid rgba(201,168,76,.22);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:600;color:rgba(255,255,255,.72);position:relative;transition:border-color .2s,box-shadow .2s;box-shadow:0 5px 14px rgba(0,0,0,.5)}
+.tseat .av.myturn{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,.22),0 0 20px rgba(201,168,76,.55)}
+.tseat .av.folded-av{opacity:.34}
+.tseat .av.winner-av{border-color:#2ecc71;box-shadow:0 0 0 3px rgba(46,204,113,.25),0 0 20px rgba(46,204,113,.65);animation:wg .6s ease-in-out 3}
+@keyframes wg{0%,100%{box-shadow:0 0 16px rgba(46,204,113,.6)}50%{box-shadow:0 0 30px rgba(46,204,113,.95)}}
+.tseat .av.you-av{border-color:rgba(201,168,76,.45)}
+.tseat.empty .av{border-style:dashed;border-color:rgba(255,255,255,.12);background:rgba(255,255,255,.015);color:rgba(255,255,255,.28);font-size:10px;letter-spacing:.08em;box-shadow:none}
+.tseat.empty .tseat-plate{opacity:.45}
+.dchip{position:absolute;bottom:-4px;right:-4px;width:19px;height:19px;border-radius:50%;background:radial-gradient(circle at 40% 30%,#e8cc7a,#c9a84c);color:#2a2410;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;border:1.5px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.5);pointer-events:none}
+.tseat-plate{display:flex;flex-direction:column;align-items:center;gap:1px;background:rgba(8,16,11,.82);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:4px 11px;backdrop-filter:blur(4px);max-width:130px}
+.tseat-name{font-size:12px;font-weight:600;color:#ece4d2;white-space:nowrap;text-overflow:ellipsis;overflow:hidden;max-width:108px;text-align:center}
+.tseat-chips{font-family:'DM Mono',monospace;font-size:11px;color:var(--gold-l)}
+.tseat-wins{font-size:9px;margin-left:5px;color:var(--gold-l);background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:0 4px;font-family:'DM Mono',monospace}
+.tseat-cards{display:flex;gap:3px;margin-top:1px}
+.tseat-act{font-size:9.5px;padding:2px 7px;border-radius:8px;background:rgba(0,0,0,.55);white-space:nowrap;min-height:13px;text-align:center;max-width:120px;overflow:hidden;text-overflow:ellipsis}
+.tact-fold{color:#e74c3c}.tact-call{color:#5aa9e6}.tact-check{color:#46d27c}.tact-raise{color:var(--gold-l)}.tact-blind{color:rgba(255,255,255,.4)}.tact-allin{color:#ff6f62;font-weight:600}
+
+/* BET CHIPS on felt */
+.chip{width:16px;height:16px;border-radius:50%;background:radial-gradient(circle at 38% 30%,#f0d896,#c9a84c 70%);border:2px solid #8a6d2a;box-shadow:inset 0 0 0 2px rgba(255,255,255,.22);flex-shrink:0}
+.tbet{position:absolute;transform:translate(-50%,-50%);background:linear-gradient(180deg,#e8cc7a,#c9a84c);color:#1a1409;border:1.5px solid #f0d896;border-radius:13px;padding:3px 11px;font-family:'DM Mono',monospace;font-size:13px;font-weight:700;white-space:nowrap;z-index:6;box-shadow:0 3px 9px rgba(0,0,0,.55),0 0 0 2px rgba(0,0,0,.18)}
+
+/* COMMUNITY */
+#community{position:absolute;top:46%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:11px;z-index:3}
+#cboard{display:flex;gap:9px}
