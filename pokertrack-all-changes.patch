+
+/* ── RANGE-GRID CLICK DETAIL ── */
+.rg-c.rg-played{cursor:pointer}
+.rg-c.rg-played:hover{outline:2px solid #fff;outline-offset:-2px}
+#rg-detail{margin-top:10px}
+#rg-detail:empty{display:none}
+.rgd-t{font-size:11px;font-weight:600;color:var(--gold-l);margin-bottom:6px}
+.rgd-empty{font-size:12px;color:rgba(255,255,255,.4);padding:4px 0}
+.rgd-row{display:flex;align-items:center;gap:9px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:11px}
+.rgd-act{font-size:9px;text-transform:uppercase;font-weight:600;border-radius:6px;padding:2px 6px;min-width:42px;text-align:center}
+.rgd-act.raise{background:rgba(201,168,76,.18);color:var(--gold-l)}
+.rgd-act.call{background:rgba(46,204,113,.16);color:#46d27c}
+.rgd-act.check{background:rgba(90,169,230,.16);color:#5aa9e6}
+.rgd-act.fold{background:rgba(255,255,255,.06);color:rgba(255,255,255,.4)}
+.rgd-cards{display:flex;align-items:center;gap:2px;flex:1}
