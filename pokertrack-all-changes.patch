+@keyframes hintpulse{0%,100%{box-shadow:0 0 0 2px var(--gold),0 0 14px rgba(201,168,76,.45)}50%{box-shadow:0 0 0 2px var(--gold),0 0 22px rgba(201,168,76,.75)}}
