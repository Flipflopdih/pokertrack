+
+function actClass(t) {
+  return t.startsWith('Fold') ? 'tact-fold'
+    : t.startsWith('Raise') ? 'tact-raise'
+    : t.startsWith('Call') ? 'tact-call'
+    : t.startsWith('Check') ? 'tact-check'
+    : t.startsWith('Blind') ? 'tact-blind'
+    : t.startsWith('All') ? 'tact-allin' : '';
+}
