+    contrib.forEach(c => { amount += lvl; c.amt -= lvl; });
+    const eligible = contrib.filter(c => !c.p.folded).map(c => c.p);
+    layers.push({ amount, eligible });
+    contrib = contrib.filter(c => c.amt > 0);
+  }
